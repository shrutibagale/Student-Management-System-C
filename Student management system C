#include <stdio.h>
#include <string.h>

struct Student {
    int roll;
    char name[30];
    float marks;
};

int main() {
    struct Student s[10];
    int n, i, searchRoll;

    printf("Enter number of students: ");
    scanf("%d", &n);

    // Add Student
    for(i = 0; i < n; i++) {
        printf("\nStudent %d\n", i + 1);

        printf("Roll No: ");
        scanf("%d", &s[i].roll);

        printf("Name: ");
        scanf("%s", s[i].name);

        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }

    // Display Students
    printf("\n--- Student Records ---\n");
    for(i = 0; i < n; i++) {
        printf("\nRoll No : %d", s[i].roll);
        printf("\nName    : %s", s[i].name);
        printf("\nMarks   : %.2f\n", s[i].marks);
    }

    // Search Student
    printf("\nEnter Roll No to Search: ");
    scanf("%d", &searchRoll);

    for(i = 0; i < n; i++) {
        if(s[i].roll == searchRoll) {
            printf("\nStudent Found");
            printf("\nRoll No : %d", s[i].roll);
            printf("\nName    : %s", s[i].name);
            printf("\nMarks   : %.2f\n", s[i].marks);
            return 0;
        }
    }

    printf("\nStudent Not Found!");

    return 0;
}

